generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  code        String?    @unique
  plu         Int?       @unique
  description String?
  unit        UnitOfMeasure @default(CONFEZIONE)
  alertThreshold Int?
  stock       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  movements   Movement[]
}

model Movement {
  id        Int          @id @default(autoincrement())
  type      MovementType
  quantity  Int
  note      String?
  createdAt DateTime     @default(now())
  productId Int
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum MovementType {
  LOAD
  UNLOAD
}

enum UnitOfMeasure {
  CONFEZIONE
  MILLILITRI
  LITRI
  GRAMMI
  ETTI
  KG
}
